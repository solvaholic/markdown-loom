{
  "name": "markdown-loom",
  "displayName": "Markdown Loom",
  "description": "Plain-markdown note taking with wikilinks, backlinks, and tasks.",
  "version": "0.2.0",
  "publisher": "markdown-loom",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/solvaholic/markdown-loom.git"
  },
  "homepage": "https://github.com/solvaholic/markdown-loom#readme",
  "bugs": {
    "url": "https://github.com/solvaholic/markdown-loom/issues"
  },
  "license": "MIT",
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test",
    "package": "vsce package"
  },
  "contributes": {
    "languages": [
      {
        "id": "markdown",
        "extensions": [
          ".md"
        ],
        "aliases": [
          "Markdown",
          "markdown"
        ]
      }
    ],
    "commands": [
      {
        "command": "markdownLoom.openWikiLink",
        "title": "Open Wiki Link",
        "enablement": "editorLangId == markdown"
      },
      {
        "command": "markdownLoom.toggleTask",
        "title": "Markdown Loom: Toggle Task",
        "enablement": "editorLangId == markdown"
      },
      {
        "command": "markdownLoom.showIndexStatus",
        "title": "Markdown Loom: Show Index Status"
      }
    ],
    "keybindings": [
      {
        "command": "markdownLoom.toggleTask",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t",
        "when": "editorTextFocus && editorLangId == markdown"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "markdownLoom.backlinks",
          "name": "Backlinks",
          "icon": "$(references)",
          "contextualTitle": "Markdown Loom Backlinks"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "markdownLoom.backlinks",
        "contents": "Open a markdown file to see notes that link to it."
      }
    ],
    "markdown.markdownItPlugins": true,
    "configuration": {
      "title": "Markdown Loom",
      "properties": {
        "markdownLoom.wikiLinkStyle": {
          "type": "string",
          "enum": [
            "name"
          ],
          "default": "name",
          "markdownDescription": "Reserved for future use. `[[` completion always inserts the note basename. Path-style insertion (`relative`, `absolute`) was removed when wikilink targets were restricted to bare names; see `docs/SPEC.md` 'Wikilink target syntax'."
        },
        "markdownLoom.taskDateFormat": {
          "type": "string",
          "enum": [
            "YYYY-MM-DD"
          ],
          "default": "YYYY-MM-DD",
          "markdownDescription": "Reserved for future use. Task dates are always written in ISO 8601 (`YYYY-MM-DD`) per `docs/SPEC.md` to keep notes interoperable with Obsidian Tasks; alternative formats are not currently honored."
        },
        "markdownLoom.queryLimitDefault": {
          "type": "number",
          "default": 50,
          "minimum": 1,
          "description": "Default maximum number of tasks returned by a `tasks` query block (Phase 2)."
        },
        "markdownLoom.autoAddDoneDate": {
          "type": "boolean",
          "default": true,
          "description": "Automatically append a done date (✅ YYYY-MM-DD) when toggling a task to done."
        },
        "markdownLoom.indexStatusSampleSize": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "description": "Number of indexed note paths shown as a sample in the 'Show Index Status' command output."
        }
      }
    }
  },
  "dependencies": {
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.6",
    "@types/node": "^22.13.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vscode/test-cli": "^0.0.4",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^2.24.0",
    "eslint": "^8.56.0",
    "glob": "^10.3.10",
    "mocha": "^10.3.0",
    "typescript": "^5.5.4"
  }
}
